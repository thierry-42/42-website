# Required on each deployment: development, staging, or production.
# Render must use staging. Production hosting must use production.
SITE_ENVIRONMENT=staging

# Optional public company profile. Leave empty until approved.
NEXT_PUBLIC_LINKEDIN_URL=

# Approved staging/testing HubSpot form. These identifiers are public embed
# configuration, not credentials. Provide all three values together.
HUBSPOT_STAGING_REGION=eu1
HUBSPOT_STAGING_PORTAL_ID=148811132
HUBSPOT_STAGING_FORM_ID=da5e2637-3fc8-4ab0-96b1-4764ecd0f16e

# A separate production form must be created and approved before launch.
# Leave every production value empty until then. Production never falls back
# to the staging form.
HUBSPOT_PRODUCTION_REGION=
HUBSPOT_PRODUCTION_PORTAL_ID=
HUBSPOT_PRODUCTION_FORM_ID=
