# Required on each deployment: development, staging, or production.
# Render must use staging. Production hosting must use production.
SITE_ENVIRONMENT=staging

# Optional public company profile. Leave empty until approved.
NEXT_PUBLIC_LINKEDIN_URL=

# Optional overrides for the approved live production HubSpot form.
# These are used only when SITE_ENVIRONMENT=production.
NEXT_PUBLIC_HUBSPOT_REGION=
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
NEXT_PUBLIC_HUBSPOT_FORM_ID=

# A separate non-production HubSpot form is not yet configured.
# Provide all three values together to enable the form in development/staging.
# Otherwise the contact page shows hello@company42.co instead of loading the
# live production form.
HUBSPOT_STAGING_REGION=
HUBSPOT_STAGING_PORTAL_ID=
HUBSPOT_STAGING_FORM_ID=
