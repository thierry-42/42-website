# Public canonical origin, for example https://www.example.com
NEXT_PUBLIC_SITE_URL=

# Optional external scheduling destination. Falls back to /contact when empty.
NEXT_PUBLIC_BOOKING_URL=

# Optional public contact and social destinations.
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_LINKEDIN_URL=

# Optional form and analytics integrations. No integration loads when empty.
NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
NEXT_PUBLIC_HUBSPOT_FORM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
